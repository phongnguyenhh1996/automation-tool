# Cloudinary: JSON đính kèm (raw) → OpenAI Responses ``input_file`` ``file_url``
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix for raw JSON (default: automation_tool/coinmap_json)
# CLOUDINARY_JSON_FOLDER=automation_tool/coinmap_json

# Required for analyze / all / chatgpt-project
OPENAI_API_KEY=
# Dashboard Prompt ID (Responses API), e.g. pmpt_...
OPENAI_PROMPT_ID=
# Optional prompt template version (omit or leave empty to omit from API)
# OPENAI_PROMPT_VERSION=3

# Optional: override model for Responses API (CLI --model wins). Example: gpt-5.2
# OPENAI_MODEL=

# Optional: model cho [INTRADAY_ALERT] và [TRADE_MANAGEMENT] sau TP1 (cùng cách chọn model).
# journal touch, watchlist touch, zone-touch, tp1 follow-up. Mặc định code: gpt-5.4-mini.
# Ưu tiên: CLI --model > biến này > mặc định (không dùng OPENAI_MODEL).
# OPENAI_MODEL_INTRADAY_ALERT=gpt-5.4-mini

# File search tool (comma-separated). Example:
# OPENAI_VECTOR_STORE_IDS=vs_69c78f5e0e908191b625be397e7471fb

# Active pair for data layout: data/{SYMBOL}/last_alert_prices.json, data/{SYMBOL}/charts/, etc.
# Optional; overrides data/.main_chart_symbol when set (see also capture --main-symbol).
# AUTOMATION_MAIN_SYMBOL=XAUUSD

# Persist conversation server-side (default true). Set false for stateless runs.
# OPENAI_RESPONSES_STORE=true

# Extra output fields (comma-separated). Default if unset:
# reasoning.encrypted_content,web_search_call.action.sources
# OPENAI_RESPONSES_INCLUDE=reasoning.encrypted_content,web_search_call.action.sources,file_search_call.results

# Telegram (for analyze / all / chatgpt-project unless --no-telegram)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Optional: listen inbound messages/commands from this chat/channel (defaults to TELEGRAM_CHAT_ID).
# TELEGRAM_LISTEN_CHAT_ID=
# Formatting: use HTML so **bold**, ## headings, `code` render (see telegram_bot.markdown_like_to_telegram_html).
# MarkdownV2 escapes everything and will look plain; legacy Markdown is limited.
# TELEGRAM_PARSE_MODE=HTML

# Optional: log bước chạy (INFO) tới channel/supergroup khác — cùng bot phải là admin trong channel
# TELEGRAM_LOG_CHAT_ID=-1003860280694

# Optional: tin ngắn tiếng Việt (bước đáng chú ý, non-tech) — cùng bot là admin trong channel
# TELEGRAM_PYTHON_BOT_CHAT_ID=

# Optional: OUTPUT_NGAN_GON (phân tích ngắn; không dùng cho log MT5) — cùng bot là admin
# TELEGRAM_OUTPUT_NGAN_GON_CHAT_ID=

# Optional: log từng bước / phản hồi đầu (hop_luu, vùng chọn, lý do bỏ qua MT5) từ apply_first_response — không dùng làm kênh out_chi_tiet chính.
# Phân tích chi tiết (out_chi_tiet) sau analyze/update gửi lên TELEGRAM_CHAT_ID; bản ngắn (output_ngan_gon) → TELEGRAM_OUTPUT_NGAN_GON_CHAT_ID.
# TELEGRAM_ANALYSIS_DETAIL_CHAT_ID=-1003344625474

# Optional: when step 2 embeds Coinmap .json files, cap size (default 1500000 chars)
# COINMAP_JSON_MAX_CHARS=1500000
# Optional: cap morning_full_analysis.json when a flow embeds that file (default: same as COINMAP_JSON_MAX_CHARS). Used on the first coinmap-automation update after each all (morning JSON + M15 + M5).
# MORNING_FULL_ANALYSIS_MAX_CHARS=1500000

# Slim again when *reading* JSON for OpenAI (default off; disk export is slimmed via coinmap.yaml slim_export_on_disk)
# COINMAP_OPENAI_SLIM=true
# M15: default 30 candles, 11 footprint bars (env overrides)
# COINMAP_OPENAI_BARS_15M=30
# COINMAP_OPENAI_FP_15M=11
# M5: default 35 candles, 16 footprint bars
# COINMAP_OPENAI_BARS_5M=35
# COINMAP_OPENAI_FP_5M=16

# Coinmap (capture / all)
# COINMAP_EMAIL=
# COINMAP_PASSWORD=

# MT5 order_send retry tuning (for REQUOTE / PRICE_CHANGED on fast markets)
# Max attempts (>=1). Default code: 3
# MT5_ORDER_SEND_MAX_ATTEMPTS=3
# Delay between retries in milliseconds. Default code: 200
# MT5_ORDER_SEND_RETRY_DELAY_MS=200

# TradingView chart tab (when tradingview_capture.login_enabled): same email as Coinmap, separate password
# TRADINGVIEW_PASSWORD=

# Optional: reuse Chrome profile for capture — see README
# PLAYWRIGHT_CHROME_USER_DATA_DIR=
