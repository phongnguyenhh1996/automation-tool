# Required for analyze / all / chatgpt-project
OPENAI_API_KEY=
# Dashboard Prompt ID (Responses API), e.g. pmpt_...
OPENAI_PROMPT_ID=
# Optional prompt template version (omit or leave empty to omit from API)
# OPENAI_PROMPT_VERSION=3

# File search tool (comma-separated). Example:
# OPENAI_VECTOR_STORE_IDS=vs_69c78f5e0e908191b625be397e7471fb

# Persist conversation server-side (default true). Set false for stateless runs.
# OPENAI_RESPONSES_STORE=true

# Extra output fields (comma-separated). Default if unset:
# reasoning.encrypted_content,web_search_call.action.sources
# OPENAI_RESPONSES_INCLUDE=reasoning.encrypted_content,web_search_call.action.sources,file_search_call.results

# Telegram (for analyze / all / chatgpt-project unless --no-telegram)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Formatting: use HTML so **bold**, ## headings, `code` render (see telegram_bot.markdown_like_to_telegram_html).
# MarkdownV2 escapes everything and will look plain; legacy Markdown is limited.
# TELEGRAM_PARSE_MODE=HTML

# Optional: when step 2 embeds Coinmap .json files, cap size (default 1500000 chars)
# COINMAP_JSON_MAX_CHARS=1500000

# Slim again when *reading* JSON for OpenAI (default off; disk export is slimmed via coinmap.yaml slim_export_on_disk)
# COINMAP_OPENAI_SLIM=true
# M15: default 30 candles, 11 footprint bars (env overrides)
# COINMAP_OPENAI_BARS_15M=30
# COINMAP_OPENAI_FP_15M=11
# M5: default 35 candles, 16 footprint bars
# COINMAP_OPENAI_BARS_5M=35
# COINMAP_OPENAI_FP_5M=16

# Coinmap (capture / all)
# COINMAP_EMAIL=
# COINMAP_PASSWORD=

# TradingView chart tab (when tradingview_capture.login_enabled): same email as Coinmap, separate password
# TRADINGVIEW_PASSWORD=

# Optional: reuse Chrome profile for capture — see README
# PLAYWRIGHT_CHROME_USER_DATA_DIR=
